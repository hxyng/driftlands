<Project Sdk="Microsoft.NET.Sdk">

  <!-- Verifies the engine-agnostic DriftLands.Core (pure C#, no UnityEngine)
       compiles and that its deterministic formulas match the Godot/GDScript
       implementation. Run with dotnet run from this folder. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <AssemblyName>DriftLands.CoreTests</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\Assets\Scripts\Core\*.cs" />
    <Compile Include="Program.cs" />
  </ItemGroup>

</Project>
